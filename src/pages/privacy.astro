---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { site } from "../data/site";

const title = "Privacy Policy | NH Well Water Treatment";
const description =
  "How NH Well Water Treatment, operated by Compass Camper LLC, collects, uses, shares, and protects your information.";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Privacy Policy", href: "/privacy" },
];
---

<BaseLayout title={title} description={description}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <Breadcrumbs items={crumbs} />
      <h1 class="mt-6 text-3xl sm:text-4xl font-bold leading-tight text-ink-900">Privacy Policy</h1>
      <p class="mt-3 text-sm text-ink-500">Last updated: {site.launchYear}</p>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 text-ink-700 leading-relaxed">
      <div>
        <h2 class="text-xl font-bold text-ink-900">Who we are</h2>
        <p class="mt-3">
          This website, NH Well Water Treatment, is operated by Compass Camper LLC, a
          marketing and lead generation company registered in Oregon and operating as
          Compass Lead Group. We connect New Hampshire well owners with independent,
          licensed local water treatment contractors. We are not a contractor and we do
          not perform water treatment work. This policy explains how we handle your
          information.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Information we collect</h2>
        <p class="mt-3">When you contact us or submit a form, we may collect:</p>
        <ul class="mt-3 list-disc pl-6 space-y-1">
          <li>Your name, phone number, and email address</li>
          <li>Your property address and town, if you provide them</li>
          <li>Details you share about your water concern</li>
          <li>Technical data such as your IP address and basic page-visit information</li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">How we use your information</h2>
        <p class="mt-3">We use the information you provide to:</p>
        <ul class="mt-3 list-disc pl-6 space-y-1">
          <li>Match you with a licensed local water treatment contractor</li>
          <li>Follow up on your request and answer your questions</li>
          <li>Improve this website and our service</li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">How your information is shared</h2>
        <p class="mt-3">
          When you submit a request, your information is shared with a licensed local
          water treatment contractor for the purpose of scheduling your free in-home
          water test and quote. We also use trusted service providers to operate this
          site, including Cloudflare for hosting and Web3Forms for form delivery. As the
          service grows we may add a call-tracking provider such as CallRail and website
          analytics such as Google Analytics. We do not sell your personal information.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Cookies and analytics</h2>
        <p class="mt-3">
          This site does not run third-party advertising trackers. If we add website
          analytics in the future, we will use it to understand general site usage, and
          we will update this policy to reflect what is collected.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">How long we keep your information</h2>
        <p class="mt-3">
          We keep your information only as long as needed for the purposes described
          here. Records of consent to be contacted are kept for at least five years, in
          line with guidance under the Telephone Consumer Protection Act.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Your rights and choices</h2>
        <p class="mt-3">You can:</p>
        <ul class="mt-3 list-disc pl-6 space-y-1">
          <li>Ask us to access or delete the personal information we hold about you</li>
          <li>Opt out of further contact at any time</li>
          <li>Reply STOP to any text message to stop text contact, or ask to be removed during any call</li>
        </ul>
        <p class="mt-3">
          If you are a California resident, you have additional rights under the
          California Consumer Privacy Act, as amended by the California Privacy Rights
          Act, including the right to know, delete, and opt out of the sale or sharing
          of personal information. To exercise any of these rights, contact us at the
          email below.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Data security</h2>
        <p class="mt-3">
          We take reasonable measures to protect the information you share with us. No
          method of transmission or storage is completely secure, so we cannot guarantee
          absolute security.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Children's privacy</h2>
        <p class="mt-3">
          This site is intended for homeowners and is not directed to children. We do
          not knowingly collect personal information from children.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Changes to this policy</h2>
        <p class="mt-3">
          We may update this policy from time to time. When we do, we will revise the
          date at the top of this page.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink-900">Contact us</h2>
        <p class="mt-3">
          For any privacy request or question, email us at
          <a href={`mailto:${site.contactEmail}`} class="text-brand-700 underline">{site.contactEmail}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
