---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GuideCard from "../../components/GuideCard.astro";
import Icon from "../../components/Icon.astro";
import { guides } from "../../data/site";

const title = "New Hampshire Well Water Guides | NH Well Water Treatment";
const description =
  "Plain-language guides to arsenic, uranium, and radon in New Hampshire well water, testing before a home sale, and choosing the right treatment system.";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Guides", href: "/guides" },
];
---

<BaseLayout title={title} description={description}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <Breadcrumbs items={crumbs} />
      <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-brand-700">Guides</p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold leading-tight text-ink-900">
        New Hampshire Well Water Guides
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-700">
        Calm, sourced guides to what is in New Hampshire well water and what to do about
        it. Every fact links back to NHDES, the USGS, the EPA, or Dartmouth so you can
        check it yourself.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {guides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <section class="bg-ink-50 border-y border-ink-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">Ready to test your well?</h2>
      <p class="mt-3 text-ink-700">
        When you are ready to move from reading to results, we can connect you with a
        licensed local contractor for a free in-home water test and a written quote.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3.5 text-base font-semibold text-ink-900 hover:bg-accent-600 transition-colors"
      >
        <Icon name="circle-check" size={20} />
        Get a Free Water Test and Quote
      </a>
    </div>
  </section>
</BaseLayout>
