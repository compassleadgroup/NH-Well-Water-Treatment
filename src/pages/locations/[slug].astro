---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ContactForm from "../../components/ContactForm.astro";
import FAQ from "../../components/FAQ.astro";
import Icon from "../../components/Icon.astro";
import { site, services, locations } from "../../data/site";
import { locationContent } from "../../data/locationContent";

export function getStaticPaths() {
  return Object.values(locationContent).map((content) => ({
    params: { slug: content.slug },
    props: { content },
  }));
}

const { content } = Astro.props;
const { town } = content;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Locations", href: "/locations" },
  { label: `${town}, ${site.stateAbbr}`, href: `/locations/${content.slug}` },
];

// Shared sources for the testing and home-sale section, appended to each town's
// own sources.
const sharedSources = [
  {
    label: "NHDES, Suggested Water Quality Testing for Private Wells (DWGB-2-1)",
    href: "https://www.des.nh.gov/sites/g/files/ehbemt341/files/documents/2020-01/dwgb-2-1.pdf",
  },
  {
    label: "New Hampshire RSA 477:4-d (private water supply disclosure)",
    href: "https://gc.nh.gov/rsa/html/xlviii/477/477-4-d.htm",
  },
  {
    label: "New Hampshire RSA 477:4-a (radon, arsenic, and lead notification)",
    href: "https://gc.nh.gov/rsa/html/xlviii/477/477-4-a.htm",
  },
];
const allSources = [...content.sources, ...sharedSources];

// Resolve nearby towns to a link when the page exists, or plain text when it is
// still planned, so navigation never 404s.
const nearby = content.nearby.map((slug) => {
  const loc = locations.find((l) => l.slug === slug);
  return {
    slug,
    town: loc ? loc.town : slug,
    built: Boolean(locationContent[slug]),
  };
});

const canonical = new URL(`/locations/${content.slug}`, site.productionUrl).href;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: `${site.brand}, ${town}`,
    description: `A marketing and lead generation service connecting ${town}, New Hampshire well owners with licensed local water treatment contractors.`,
    url: canonical,
    areaServed: { "@type": "City", name: `${town}, New Hampshire` },
    telephone: site.phoneTel,
    email: site.contactEmail,
    provider: { "@type": "Organization", name: site.legalEntity },
  },
];
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} schema={schema}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <Breadcrumbs items={crumbs} />
      <p class="mt-6 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-brand-700">
        <Icon name="map-pin" size={16} />
        {town}, {content.county} County
      </p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold leading-tight text-ink-900">
        Well Water Treatment in {town}, New Hampshire
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-700">{content.heroSub}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3.5 text-base font-semibold text-ink-900 hover:bg-accent-600 transition-colors"
        >
          <Icon name="circle-check" size={20} />
          Get a Free Water Test and Quote
        </a>
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center justify-center gap-2 rounded-md border border-brand-700 px-6 py-3.5 text-base font-semibold text-brand-700 hover:bg-brand-50 transition-colors"
        >
          <Icon name="phone" size={18} />
          Call {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section 1: Why this town's wells carry these contaminants -->
    <section class="py-12 sm:py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        Why {town} wells carry these contaminants
      </h2>
      <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
        {content.whyParas.map((p) => <p>{p}</p>)}
      </div>
      <div class="mt-6">
        <p class="text-sm font-semibold uppercase tracking-wide text-ink-500">Around {town}</p>
        <ul class="mt-3 flex flex-wrap gap-2">
          {
            content.features.map((f) => (
              <li class="inline-flex items-center gap-1 rounded-full bg-brand-50 px-3 py-1 text-sm text-brand-800">
                <Icon name="map-pin" size={14} />
                {f}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Section 2: Services available locally -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        Water treatment services available in {town}
      </h2>
      <p class="mt-3 text-ink-700">
        These services are provided by the licensed local contractor you are matched
        with, sized to your {town} well and your home.
      </p>
    </section>
  </div>

  <section class="pb-4">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section 3: Common local issues -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        Common well water issues in the {town} area
      </h2>
      <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
        {content.coContaminants.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <!-- Section 4: How to test and treat -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        How to test and treat your {town} well
      </h2>
      <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
        <p>
          Testing is straightforward. You can send a sample to a New Hampshire
          accredited laboratory, order a test kit, or have the licensed local contractor
          we connect you with run a free in-home test. NHDES recommends a standard
          analysis every three to five years, with bacteria and nitrate tested yearly.
        </p>
        <p>
          If you are buying or selling a {town} home, water comes up at the closing
          table. New Hampshire requires sellers of one-to-four-family homes to disclose
          details about the private water supply, including the date of the most recent
          water test, and a separate state notification reminds buyers that radon and
          arsenic can occur in New Hampshire well water and that testing is recommended.
        </p>
        <p>
          The treatment path is the same three steps everywhere we work: request a free
          in-home test, the contractor tests your {town} water and reviews the results
          with you, and you receive a written, itemized quote with no obligation.
        </p>
      </div>
    </section>

    <!-- Section 5: Nearby areas -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">Nearby areas we serve</h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {
          nearby.map((n) =>
            n.built ? (
              <li>
                <a
                  href={`/locations/${n.slug}`}
                  class="inline-flex items-center gap-1 rounded-full border border-ink-200 px-4 py-2 text-sm font-medium text-brand-700 hover:bg-brand-50"
                >
                  <Icon name="map-pin" size={14} />
                  {n.town}, {site.stateAbbr}
                </a>
              </li>
            ) : (
              <li>
                <span class="inline-flex items-center gap-1 rounded-full border border-ink-200 px-4 py-2 text-sm font-medium text-ink-500">
                  <Icon name="map-pin" size={14} />
                  {n.town}, {site.stateAbbr}
                </span>
              </li>
            )
          )
        }
      </ul>
      <a
        href="/locations"
        class="mt-6 inline-flex items-center gap-1 font-semibold text-brand-700 hover:gap-2 transition-all"
      >
        See all areas we serve
        <Icon name="arrow-right" size={16} />
      </a>
    </section>
  </div>

  <!-- Section 6: FAQ -->
  <div class="bg-ink-50 border-t border-ink-200">
    <FAQ items={content.faqs} heading={`${town} well water questions`} />
  </div>

  <!-- Sources -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-500">Sources</h2>
      <ul class="mt-3 space-y-1 text-sm">
        {
          allSources.map((s) => (
            <li>
              <a href={s.href} rel="noopener noreferrer" class="text-brand-700 underline">{s.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Final CTA + form -->
  <section class="bg-white border-t border-ink-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        Get your {town} well tested
      </h2>
      <p class="mt-3 text-ink-700">
        A licensed local contractor will test your water, explain the results, and give
        you a written quote. No obligation.
      </p>
      <div class="mt-8 rounded-xl border border-ink-200 bg-white p-6 sm:p-8 shadow-sm">
        <ContactForm source={`Location: ${town}, NH`} id={`loc-${content.slug}`} />
      </div>
    </div>
  </section>
</BaseLayout>
