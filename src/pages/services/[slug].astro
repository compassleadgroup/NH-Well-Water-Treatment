---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ContactForm from "../../components/ContactForm.astro";
import FAQ from "../../components/FAQ.astro";
import Icon from "../../components/Icon.astro";
import { site, services, locations } from "../../data/site";
import { serviceContent } from "../../data/serviceContent";
import { isLocationBuilt } from "../../data/builtLocations";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const content = serviceContent[service.slug];

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: service.name, href: `/services/${service.slug}` },
];

// Shared, realistic process. Service-specific follow-up is appended below.
const process = [
  {
    title: "Request a free in-home water test",
    body: "Use the form or call. A licensed local contractor sets up a visit at no cost.",
  },
  {
    title: "The contractor tests your water and reviews the results",
    body: "You get a plain explanation of what is in your water and what it means.",
  },
  {
    title: "You get a written, itemized recommendation and quote",
    body: "If treatment makes sense, the recommendation is matched to your water, with the cost in writing.",
  },
  {
    title: "The contractor installs the system",
    body: "If you choose to proceed, the contractor installs and configures the system for your home.",
  },
  {
    title: "The contractor confirms performance and explains maintenance",
    body: "You leave with a clear maintenance schedule and, where relevant, a retest plan.",
  },
];

const relatedServices = content.related.services
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is (typeof services)[number] => Boolean(s));

const relatedLocations = content.related.locations
  .map((slug) => {
    const loc = locations.find((l) => l.slug === slug);
    return loc ? { ...loc, built: isLocationBuilt(loc.slug) } : null;
  })
  .filter((l): l is NonNullable<typeof l> => Boolean(l));

const h1 = content.h1 ?? `${service.name} in New Hampshire`;

const canonical = new URL(`/services/${service.slug}`, site.productionUrl).href;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: h1,
    serviceType: "Water treatment contractor referral service",
    description: `Connecting New Hampshire homeowners with licensed local contractors for ${service.name.toLowerCase()}.`,
    areaServed: { "@type": "State", name: "New Hampshire" },
    provider: { "@type": "Organization", name: site.legalEntity },
    url: canonical,
  },
];
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} schema={schema}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <Breadcrumbs items={crumbs} />
      <div class="mt-6 flex items-center gap-3">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-700 text-white">
          <Icon name={service.icon} size={24} />
        </span>
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">Services</p>
      </div>
      <h1 class="mt-4 text-3xl sm:text-4xl font-bold leading-tight text-ink-900">
        {h1}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-700">{content.heroSub}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3.5 text-base font-semibold text-ink-900 hover:bg-accent-600 transition-colors"
        >
          <Icon name="circle-check" size={20} />
          Get a Free Water Test and Quote
        </a>
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center justify-center gap-2 rounded-md border border-brand-700 px-6 py-3.5 text-base font-semibold text-brand-700 hover:bg-brand-50 transition-colors"
        >
          <Icon name="phone" size={18} />
          Call {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section 1: What this is and why NH wells need it -->
    <section class="py-12 sm:py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        What it is and why New Hampshire wells need it
      </h2>
      <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
        {content.intro.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <!-- Section 2: How the contractor approaches it -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">{content.methodsHeading}</h2>
      <div class="mt-8 space-y-6">
        {
          content.methods.map((m) => (
            <div class="flex gap-4">
              <Icon name="circle-check" size={22} class="mt-1 shrink-0 text-brand-700" />
              <div>
                <h3 class="text-lg font-semibold text-ink-900">{m.title}</h3>
                <p class="mt-1 text-ink-700 leading-relaxed">{m.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Section 3: What to expect -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">What to expect</h2>
      <ol class="mt-8 space-y-6">
        {
          process.map((step, i) => (
            <li class="flex gap-4">
              <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-700 font-bold text-white">
                {i + 1}
              </span>
              <div>
                <h3 class="font-semibold text-ink-900">{step.title}</h3>
                <p class="mt-1 text-ink-700 leading-relaxed">{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
      {
        content.followUp && (
          <p class="mt-6 rounded-md bg-brand-50 px-4 py-3 text-sm text-ink-700">{content.followUp}</p>
        )
      }
    </section>

    <!-- Section 4: Cost context -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">{content.costHeading}</h2>
      <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
        {content.cost.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <!-- Optional extra sections (for example Arsenic-III versus Arsenic-V) -->
    {
      content.extraSections?.map((sec) => (
        <section id={sec.id} class="py-12 sm:py-16 border-t border-ink-200 scroll-mt-24">
          <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">{sec.heading}</h2>
          <div class="mt-6 space-y-4 text-ink-700 leading-relaxed">
            {sec.paras.map((p) => <p>{p}</p>)}
          </div>
        </section>
      ))
    }

    <!-- Section 5: Related services and where this fits -->
    <section class="py-12 sm:py-16 border-t border-ink-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">Where this fits</h2>
      <p class="mt-4 text-ink-700">Related services a contractor often pairs with this one:</p>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          relatedServices.map((s) => (
            <li>
              <a
                href={`/services/${s.slug}`}
                class="inline-flex items-center gap-1 rounded-full border border-ink-200 px-4 py-2 text-sm font-medium text-brand-700 hover:bg-brand-50"
              >
                {s.name}
                <Icon name="arrow-right" size={14} />
              </a>
            </li>
          ))
        }
      </ul>

      <p class="mt-6 text-ink-700">Serving well owners in these and other New Hampshire towns:</p>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          relatedLocations.map((l) =>
            l.built ? (
              <li>
                <a
                  href={`/locations/${l.slug}`}
                  class="inline-flex items-center gap-1 rounded-full border border-ink-200 px-4 py-2 text-sm font-medium text-ink-700 hover:bg-ink-100"
                >
                  <Icon name="map-pin" size={14} class="text-brand-700" />
                  {l.town}, {site.stateAbbr}
                </a>
              </li>
            ) : (
              <li>
                <span class="inline-flex items-center gap-1 rounded-full border border-ink-200 px-4 py-2 text-sm font-medium text-ink-500">
                  <Icon name="map-pin" size={14} />
                  {l.town}, {site.stateAbbr}
                </span>
              </li>
            )
          )
        }
      </ul>

      <a
        href={content.related.guide.href}
        class="mt-8 inline-flex items-center gap-2 font-semibold text-brand-700 hover:gap-3 transition-all"
      >
        <Icon name="book-open" size={18} />
        Read: {content.related.guide.label}
      </a>
    </section>
  </div>

  <!-- Next steps: start with a test, plus the higher-ticket whole-house path -->
  <section class="py-4">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-brand-200 bg-brand-50 p-6 sm:flex sm:items-center sm:justify-between sm:gap-6">
        <div>
          <p class="font-semibold text-ink-900">Not sure what is in your water? Start with a test.</p>
          <p class="mt-1 text-sm text-ink-700">
            A free in-home water test shows exactly what your well needs.
            {
              service.slug !== "whole-house-water-treatment" && (
                <Fragment>
                  {" "}For a home with several contaminants, compare
                  <a href="/services/whole-house-water-treatment" class="text-brand-700 underline"> whole-house water treatment</a>.
                </Fragment>
              )
            }
          </p>
        </div>
        <a
          href="/services/well-water-testing"
          class="mt-4 sm:mt-0 inline-flex shrink-0 items-center justify-center gap-2 rounded-md bg-accent-500 px-5 py-3 text-sm font-semibold text-ink-900 hover:bg-accent-600 transition-colors"
        >
          <Icon name="test-tube" size={18} />
          Well Water Testing
        </a>
      </div>
    </div>
  </section>

  <!-- Section 6: FAQ -->
  <div class="bg-ink-50 border-t border-ink-200">
    <FAQ items={content.faqs} />
  </div>

  <!-- Sources (visible authority citations) -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-500">Sources</h2>
      <ul class="mt-3 space-y-1 text-sm">
        {
          content.sources.map((s) => (
            <li>
              <a href={s.href} rel="noopener noreferrer" class="text-brand-700 underline">{s.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Final CTA + form -->
  <section class="bg-white border-t border-ink-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">
        Start with a free in-home water test
      </h2>
      <p class="mt-3 text-ink-700">
        A licensed local contractor will test your water, explain the results, and
        give you a written quote. No obligation.
      </p>
      <div class="mt-8 rounded-xl border border-ink-200 bg-white p-6 sm:p-8 shadow-sm">
        <ContactForm source={`Service: ${service.name}`} id={`svc-${service.slug}`} />
      </div>
    </div>
  </section>
</BaseLayout>
