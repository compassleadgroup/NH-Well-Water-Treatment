---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ContactForm from "../components/ContactForm.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";

const title = "Contact | Free Water Test & Quote | NH Well Water Treatment";
const description =
  "Request a free in-home water test and quote from a licensed New Hampshire water treatment contractor. Call (603) 555-0100 or submit the form.";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Contact", href: "/contact" },
];

const trustBar = ["Free in-home test", "No obligation", "Licensed and insured contractors"];

const nextSteps = [
  "We connect you with a licensed local contractor",
  "The contractor schedules a free in-home water test",
  "You get your results explained and a written quote",
];
---

<BaseLayout title={title} description={description}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <Breadcrumbs items={crumbs} />
      <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-brand-700">Get in touch</p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold leading-tight text-ink-900">
        Request a Free Water Test and Quote
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-700">
        A licensed local contractor will reach out to schedule a free in-home water
        test and provide a written quote. There is no cost and no obligation.
      </p>
      <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2">
        {
          trustBar.map((item) => (
            <li class="flex items-center gap-2 text-sm text-ink-700">
              <Icon name="check" size={16} class="text-brand-700" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <div class="rounded-xl border border-ink-200 bg-white p-6 sm:p-8 shadow-sm">
            <ContactForm source="Contact page" id="contact-form" />
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="rounded-xl border border-ink-200 bg-ink-50 p-6">
            <h2 class="text-lg font-semibold text-ink-900">Prefer to call?</h2>
            <a
              href={`tel:${site.phoneTel}`}
              class="mt-3 inline-flex items-center gap-2 text-2xl font-bold text-brand-700 hover:text-brand-800"
            >
              <Icon name="phone" size={24} />
              {site.phoneDisplay}
            </a>
            <p class="mt-3 flex items-center gap-2 text-sm text-ink-600">
              <Icon name="clock" size={16} class="text-ink-500" />
              {site.hours}
            </p>
          </div>

          <div class="rounded-xl border border-ink-200 p-6">
            <h2 class="text-lg font-semibold text-ink-900">What happens next</h2>
            <ol class="mt-4 space-y-3">
              {
                nextSteps.map((step, i) => (
                  <li class="flex gap-3 text-sm text-ink-700">
                    <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-700 text-xs font-bold text-white">
                      {i + 1}
                    </span>
                    <span>{step}</span>
                  </li>
                ))
              }
            </ol>
          </div>

          <div class="rounded-xl border border-ink-200 p-6">
            <h2 class="text-lg font-semibold text-ink-900">Where we work</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-700">
              We serve private-well homeowners across New Hampshire, with a focus on the
              Lakes Region and the inland Strafford and Seacoast areas. If you do not see
              your town listed, call us and we will connect you with a contractor who
              serves your area.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
