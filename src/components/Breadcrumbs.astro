---
import Icon from "./Icon.astro";
import { site } from "../data/site";

export interface Crumb {
  label: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.label,
    item: new URL(item.href, site.productionUrl).href,
  })),
};
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-1 text-ink-500">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <Icon name="chevron-right" size={14} class="text-ink-400" />}
          {
            i < items.length - 1 ? (
              <a href={item.href} class="hover:text-brand-700">{item.label}</a>
            ) : (
              <span class="text-ink-700" aria-current="page">{item.label}</span>
            )
          }
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
