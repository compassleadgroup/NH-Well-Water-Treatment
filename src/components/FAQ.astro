---
import Icon from "./Icon.astro";

export interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
}

const { items, heading = "Frequently Asked Questions" } = Astro.props;

// FAQPage JSON-LD. The acceptedAnswer text is the same string rendered in the
// visible accordion below, so the schema matches the visible answer exactly.
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class="py-16 sm:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl sm:text-3xl font-bold text-ink-900">{heading}</h2>
    <div class="mt-8 divide-y divide-ink-200 border-t border-b border-ink-200">
      {
        items.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 text-left font-semibold text-ink-900 [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <Icon
                name="chevron-down"
                size={20}
                class="shrink-0 text-brand-700 transition-transform group-open:rotate-180"
              />
            </summary>
            <p class="mt-3 text-ink-700 leading-relaxed">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
