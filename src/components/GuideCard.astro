---
import Icon from "./Icon.astro";
import type { GuideItem } from "../data/site";

interface Props {
  guide: GuideItem;
}

const { guide } = Astro.props;
---

<a
  href={`/guides/${guide.slug}`}
  class="group flex h-full flex-col rounded-lg border border-ink-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md sm:p-8"
>
  <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-700">
    <Icon name="book-open" size={24} />
  </span>
  <h3 class="mt-4 text-lg font-semibold text-ink-900">{guide.title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-700">{guide.excerpt}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 group-hover:gap-2 transition-all">
    Read the guide
    <Icon name="arrow-right" size={16} />
  </span>
</a>
